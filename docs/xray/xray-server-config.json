{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "<UUID>",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.microsoft.com:443", 
          "xver": 0,
          "serverNames": [
            "www.microsoft.com",
            "microsoft.com"
          ],
          "privateKey": "<PRIVATE_KEY>",
          "shortIds": ["<SHORT_ID>"]
        }
      }
    },
    // 2. 备用节点：Hysteria 2 多端口入站 (UDP)
    {
      "port": "17312,27312,16321,12312,19312",
      "protocol": "hysteria",
      "tag": "hysteria_udp_backup",
      "settings": {
        "version": 2,
        "auth": "<PASSWORD>",
        "masquerade": {
          "type": "proxy",
          "url": "https://news.ycombinator.com/",
          "rewriteHost": true
        }
      },
      "streamSettings": {
        "network": "hysteria",
        "security": "tls",
        "tlsSettings": {
          "serverName": "miacro.me",
          "alpn": ["h3"],
          "certificates": [
            {
              "certificateFile": "/etc/nginx/certs/signed_chain.crt",
              "keyFile": "/etc/nginx/certs/self/domain.key"
            }
          ]
        },
        "hysteriaSettings": {
          "version": 2
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
